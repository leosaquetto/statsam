# .github/workflows/statsfm_rapido.yml
name: Stats.fm - Dados Rápidos

on:
  schedule:
    - cron: '*/5 * * * *'  # A cada 5 minutos
  workflow_dispatch:

jobs:
  update-rapido:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      
      - name: Coletar dados rápidos
        run: |
          pip install requests
          python statsfm_rapido.py
      
      - name: Commit e push
        run: |
          git config user.email "bot@leouol.com"
          git config user.name "StatsFM Bot"
          git add statsfm_rapido.json
          git diff --quiet && git diff --staged --quiet || (git commit -m "Atualiza dados rápidos [skip ci]" && git push)
